{"cells":[{"cell_type":"markdown","source":["Monto Carlo Off-Policy theoretical trade-offs in action. **Ordinary Importance Sampling (OIS)** is unbiased but suffers from extreme variance (the \"spikes\" are much larger), while **Weighted Importance Sampling (WIS)** is biased initially but much more stable.\n","\n","`Prof.Kiran Kumar Eranki`"],"metadata":{"id":"WIATUQiYFcJL"}},{"cell_type":"code","source":["import numpy as np\n","\n","def off_policy_mc_simulator():\n","    # 1. Initialization (Matching the grid from your slides)\n","    states = ['w', 'x', 'y', 'z']\n","    actions = ['L', 'R', 'exit']\n","    gamma = 0.9\n","    prob_b = 1/3 # Probability of action under behavior policy b\n","\n","    # Q-table: Expected returns\n","    Q = {s: {a: 0.0 for a in actions} for s in states}\n","    # C-table: Cumulative weights for Weighted Importance Sampling\n","    C = {s: {a: 0.0 for a in actions} for s in states}\n","    # Target Policy pi: Initially greedy (Starts by preferring Right for x and y)\n","    pi = {'w': 'exit', 'x': 'R', 'y': 'R', 'z': 'exit'}\n","\n","    print(\"--- Off-Policy MC Interactive Simulator ---\")\n","    print(\"Format for episode: state,action,reward state,action,reward ...\")\n","    print(\"Example(Sucess Path): x,R,0 y,R,0 z,exit,10| (Failure Path): x,L,0 w,exit,-100\")\n","\n","    num_episodes = int(input(\"\\nHow many episodes do you want to input? \"))\n","\n","    for i in range(num_episodes):\n","        raw_input = input(f\"\\nEnter Episode {i+1}: \")\n","        # Parse input: \"x,R,0 y,R,0 z,exit,10\" -> [(1, 'R', 0), (2, 'R', 0), (3, 'exit', 10)]\n","        try:\n","            episode = []\n","            for step in raw_input.split():\n","                s, a, r = step.split(',')\n","                episode.append((s, a, float(r)))\n","        except ValueError:\n","            print(\"Invalid format. Skipping episode.\")\n","            continue\n","\n","        G = 0.0\n","        W = 1.0\n","\n","        print(f\"\\nProcessing Episode {i+1} Backwards:\")\n","        # 2. Backward Pass (The core algorithm)\n","        for t in range(len(episode) - 1, -1, -1):\n","            s_t, a_t, r_t_plus_1 = episode[t]\n","            G = gamma * G + r_t_plus_1\n","\n","            # Weighted Importance Sampling Updates\n","            C[s_t][a_t] += W\n","            Q[s_t][a_t] += (W / C[s_t][a_t]) * (G - Q[s_t][a_t])\n","\n","            # Policy Improvement (Update Target Policy)\n","            pi[s_t] = max(Q[s_t], key=Q[s_t].get)\n","\n","            print(f\" -> State {s_t} ({a_t}): Q={Q[s_t][a_t]:.2f}, C={C[s_t][a_t]:.2f}, W={W:.2f}\")\n","\n","            # 3. Pruning Condition (Slide Rule: if At != pi(St) then exit)\n","            if a_t != pi[s_t]:\n","                print(f\" !!! Action {a_t} != Target Policy {pi[s_t]}. Pruning further updates.\")\n","                break\n","\n","            # Update Weight for next (earlier) step: W = W * (pi(a|s) / b(a|s))\n","            # Since target policy is greedy, pi(a|s) = 1.0\n","            W = W * (1.0 / prob_b)\n","\n","    # Final Grid Summary\n","    print(\"\\n\" + \"=\"*50)\n","    print(\"FINAL GRID STATE\")\n","    print(\"=\"*50)\n","    print(f\"{'State':<6} | {'Best Action':<12} | {'Max Q-Value':<12} | {'Total Weight (C)':<15}\")\n","    print(\"-\" * 55)\n","    for s in states:\n","        best_a = pi[s]\n","        print(f\"{s:<6} | {best_a:<12} | {Q[s][best_a]:<12.2f} | {C[s][best_a]:<15.2f}\")\n","\n","# Run the simulator\n","off_policy_mc_simulator()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"XFKsywvxOutO","executionInfo":{"status":"ok","timestamp":1774127717422,"user_tz":-330,"elapsed":37934,"user":{"displayName":"Dr.KiranKumar Eranki","userId":"10321293561882899369"}},"outputId":"2f66b3c8-4ce8-4aae-fa84-0e0d08bcf550"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["--- Off-Policy MC Interactive Simulator ---\n","Format for episode: state,action,reward s